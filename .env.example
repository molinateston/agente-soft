# .env do Agente Soft — copie pra ~/lean-bridge/.env e preencha.
# IMPORTANTE: NÃO existe token do Claude aqui. O runtime usa o login
# nativo (claude login), salvo em ~/.claude/. Esse é o modelo lean.
#
# REGRA DO ARQUIVO: o valor é tudo DEPOIS do "=". NÃO ponha comentário na
# mesma linha do valor (ex: TOKEN=abc # do BotFather) — o comentário fica
# em linha própria, acima da chave. (O parser tolera " # ..." inline, mas
# não arrisque.)

# Token do bot, do @BotFather:
TELEGRAM_BOT_TOKEN=
# Seu chat id (capturado na instalação: você manda uma msg no bot). Só você fala com o agente:
OWNER_CHAT_ID=
# Nome do agente e do dono — entram na saudação de boot ("✅ No ar! Sou o ...").
# Mantenha as ASPAS: nomes com apóstrofo (D'Avila, Sant'Ana) quebram o parsing sem elas.
AGENT_NAME=""
OWNER_NAME=""
# Modelo padrão: sonnet (padrão). Use opus[1m] só se o dono pedir.
CLAUDE_MODEL=sonnet

# Caminhos: deixe em branco — o bridge resolve sozinho a partir de ~/lean-bridge
# (WORK_DIR = diretório do script; BRAIN_DIR = ${WORK_DIR}/brain etc.).
# Só descomente e ajuste se precisar APONTAR pra um caminho diferente do padrão.
# WORK_DIR=
# PERSONA_DIR=
# BRAIN_DIR=

# ---- Opcionais ----
# Grupo com tópicos (se usar):
# GROUP_CHAT_ID=
# Quem pode comandar DENTRO do grupo (CSV de user ids; o OWNER já entra sempre).
# Vazio = grupo fecha, só o OWNER fala. Sem isso, membro do grupo teria Bash livre na VPS.
# ALLOWED_SENDERS=
# CLAUDE_EFFORT=medium
# Watchdog de INATIVIDADE: NÃO há teto fixo de tempo. Tarefa que dá sinal de vida
# (qualquer output do claude) roda até terminar. Só mata se TRAVAR de verdade — nenhum
# output por STALL_MIN minutos — ou bater o teto absoluto anti-runaway (HARD_CAP_MIN).
# STALL_MIN=10
# HARD_CAP_MIN=120
# Teto de anexo em MB (default 15):
# MAX_FILE_MB=15
# Teto global de claudes simultâneos (default 3 — protege VPS pequena de OOM):
# MAX_CONCURRENT=3

# ---- Publicar site/landing (soft-funil-render / soft-proposta) ----
# Só preencha se for usar o agente pra PUBLICAR páginas no Cloudflare Pages.
# Sem essas 2 chaves, os scripts de deploy abortam com erro claro.
# Token Cloudflare com permissão Pages:Edit:
# CLOUDFLARE_API_TOKEN=
# Account id da conta Cloudflare:
# CLOUDFLARE_ACCOUNT_ID=
